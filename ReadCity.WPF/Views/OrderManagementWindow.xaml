<Window x:Class="ReadCity.WPF.Views.OrderManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление заказами" 
        Width="900" Height="600"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="#FFFFFF">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Управление заказами" 
                   FontFamily="Calibri" FontSize="22" FontWeight="Bold"
                   Foreground="#B8860B" Margin="0,0,0,15"/>

        <DataGrid x:Name="OrdersDataGrid" Grid.Row="1"
                  AutoGenerateColumns="False" CanUserAddRows="False"
                  FontFamily="Calibri" FontSize="13"
                  SelectionChanged="OrdersDataGrid_SelectionChanged"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№" Binding="{Binding OrderNumber}" Width="60"/>
                <DataGridTextColumn Header="Дата заказа" Binding="{Binding OrderDate, StringFormat='dd.MM.yyyy'}" Width="120"/>
                <DataGridTextColumn Header="Дата доставки" Binding="{Binding DeliveryDate, StringFormat='dd.MM.yyyy'}" Width="120"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status.Name}" Width="120"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding User.FullName}" Width="*"/>
                <DataGridTextColumn Header="Код получения" Binding="{Binding ReceiptCode}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Background="#F5F5F5" Padding="15" Margin="0,10,0,0" CornerRadius="5">
            <Grid Margin="0,5,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Дата доставки:" FontFamily="Calibri" FontSize="14"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <DatePicker x:Name="DeliveryDatePicker" Grid.Column="1"
                            FontFamily="Calibri" FontSize="14" Width="130"
                            VerticalAlignment="Center"/>

                <TextBlock Grid.Column="3" Text="Статус:" FontFamily="Calibri" FontSize="14"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox x:Name="StatusComboBox" Grid.Column="4"
                          FontFamily="Calibri" FontSize="14" Width="150"
                          DisplayMemberPath="Name" SelectedValuePath="StatusId"
                          VerticalAlignment="Center"/>

                <Button Content="Сохранить" Grid.Column="6"
                        Background="#B8860B" Foreground="White"
                        FontFamily="Calibri" FontSize="14"
                        Padding="15,8" BorderThickness="0" Cursor="Hand"
                        Click="SaveOrderButton_Click"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>