<Window x:Class="ReadCity.WPF.Views.ReceiptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Талон заказа" 
        Width="500" Height="550"
        MinWidth="400" MinHeight="450"
        WindowStartupLocation="CenterOwner"
        Background="#FFFFFF"
        ResizeMode="CanResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#DAA520" Padding="15" CornerRadius="5" Margin="0,0,0,15">
            <TextBlock Text="Талон заказа" 
                       FontFamily="Calibri" FontSize="20" FontWeight="Bold"
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>
        
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <TextBlock x:Name="ReceiptTextBlock" 
                       FontFamily="Courier New" FontSize="13"
                       TextWrapping="Wrap" 
                       Foreground="#333333"
                       Margin="0,0,0,15"/>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,10">
            <Button Content="Сохранить в TXT" 
                    Background="#B8860B" Foreground="White"
                    FontFamily="Calibri" FontSize="14"
                    Padding="20,10" Margin="0,0,15,0"
                    BorderThickness="0" Cursor="Hand"
                    Click="SaveButton_Click"/>
            <Button Content="Закрыть" 
                    Background="Gray" Foreground="White"
                    FontFamily="Calibri" FontSize="14"
                    Padding="20,10" BorderThickness="0" Cursor="Hand"
                    Click="CloseButton_Click"/>
        </StackPanel>

        <TextBlock x:Name="StatusTextBlock" Grid.Row="3"
                   FontFamily="Calibri" FontSize="20"
                   Foreground="Green" 
                   HorizontalAlignment="Center"
                   Visibility="Collapsed"/>
    </Grid>
</Window>
