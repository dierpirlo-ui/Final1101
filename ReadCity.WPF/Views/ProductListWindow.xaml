<Window x:Class="ReadCity.WPF.Views.ProductListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Читай город — Каталог товаров"
        Height="600" Width="900"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#FFFFFF">

    <Window.Resources>
        <Style x:Key="ProductCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#DAA520"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Width" Value="260"/>
            <Setter Property="Height" Value="420"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Padding" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#DAA520">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0" Source="/Resources/icon.png"/>

            <TextBlock Grid.Column="1" Text="Читай город"
                       FontFamily="Calibri" FontSize="28" FontWeight="Bold"
                       Foreground="White" VerticalAlignment="Center"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="20,0">
                <TextBlock x:Name="UserNameTextBlock" FontFamily="Calibri"
                           Foreground="White" FontSize="14"
                           VerticalAlignment="Center"/>
                <Button x:Name="LoginButton" Content="Войти"
                        Background="#B8860B" Foreground="White"
                        FontFamily="Calibri" FontSize="14"
                        Padding="20,10" BorderThickness="0"
                        Cursor="Hand" Click="LoginButton_Click"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Background="#F5F5F5" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="SearchTextBox" Grid.Column="0"
                     FontFamily="Calibri" FontSize="14"
                     TextChanged="FilterChanged"
                     Tag="Поиск по названию..."/>

            <ComboBox x:Name="ManufacturerComboBox" Grid.Column="1"
                      Width="180" Margin="5,0" FontFamily="Calibri" FontSize="14"
                      SelectionChanged="FilterChanged"/>

            <TextBox x:Name="MinPriceTextBox" Grid.Column="2"
                     Width="80" Margin="5,0" FontFamily="Calibri" FontSize="14"
                     Tag="Цена от"
                     TextChanged="FilterChanged"/>

            <TextBox x:Name="MaxPriceTextBox" Grid.Column="3"
                     Width="80" Margin="5,0" FontFamily="Calibri" FontSize="14"
                     Tag="Цена до"
                     TextChanged="FilterChanged"/>

            <ComboBox x:Name="SortComboBox" Grid.Column="4"
                      Width="160" Margin="5,0" FontFamily="Calibri" FontSize="14"
                      SelectionChanged="FilterChanged">
                <ComboBoxItem Content="По названию ↑" Tag="NameAsc"/>
                <ComboBoxItem Content="По названию ↓" Tag="NameDesc"/>
                <ComboBoxItem Content="По цене ↑" Tag="PriceAsc"/>
                <ComboBoxItem Content="По цене ↓" Tag="PriceDesc"/>
            </ComboBox>
        </Grid>

        <TextBlock x:Name="CounterTextBlock" Grid.Row="2"
                   FontFamily="Calibri" FontSize="14" Margin="10"
                   Foreground="Gray"/>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ProductsItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ProductCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Image Grid.Row="0" 
                                       Source="{Binding PhotoPath}" 
                                       Height="120"
                                       Stretch="Uniform" 
                                       Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="1" 
                                           Text="{Binding Name}"
                                           FontFamily="Calibri" 
                                           FontWeight="Bold"
                                           FontSize="14" 
                                           TextWrapping="Wrap"
                                           MaxHeight="100"/>

                                <TextBlock Grid.Row="2" 
                                           Text="{Binding Description}"
                                           FontFamily="Calibri" 
                                           FontSize="11"
                                           TextWrapping="Wrap" 
                                           TextTrimming="WordEllipsis"
                                           Foreground="Gray"
                                           MaxHeight="100" 
                                           Margin="0,4,0,0"/>

                                <TextBlock Grid.Row="3" 
                                           FontFamily="Calibri" 
                                           FontSize="12" 
                                           Margin="0,6,0,0">
                                    <Run Text="Производитель: "/>
                                    <Run Text="{Binding Manufacturer.Name}"/>
                                </TextBlock>

                                <TextBlock Grid.Row="4" 
                                           FontFamily="Calibri" 
                                           FontSize="13" 
                                           FontWeight="Bold">
                                    <Run Text="Цена: "/>
                                    <Run Text="{Binding DiscountedPrice, Mode=OneWay, StringFormat='{}{0:N2} руб.'}"
                                            Foreground="#B8860B"/>
                                </TextBlock>

                                <Grid Grid.Row="5"/>

                                <Button Grid.Row="6" 
                                        Content="Заказать"
                                        Background="#B8860B" 
                                        Foreground="White"
                                        FontFamily="Calibri" 
                                        FontSize="13"
                                        Padding="10,6" 
                                        BorderThickness="0"
                                        Cursor="Hand" 
                                        Tag="{Binding}"
                                        Click="OrderButton_Click"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right" VerticalAlignment="Center" Margin="15,0">
            <Button x:Name="ViewOrderButton" Content="Просмотр заказа"
                    Visibility="Collapsed"
                    Background="#DAA520" Foreground="White"
                    FontFamily="Calibri" FontSize="14"
                    Padding="15,8" Margin="5,0" BorderThickness="0"
                    Cursor="Hand" Click="ViewOrderButton_Click"/>
            <Button x:Name="OrdersManagementButton" Content="Управление заказами"
                    Visibility="Collapsed"
                    Background="#DAA520" Foreground="White"
                    FontFamily="Calibri" FontSize="14"
                    Padding="15,8" Margin="5,0" BorderThickness="0"
                    Cursor="Hand" Click="OrdersManagementButton_Click"/>
        </StackPanel>
    </Grid>
</Window>