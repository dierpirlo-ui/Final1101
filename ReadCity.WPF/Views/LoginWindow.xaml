<Window x:Class="ReadCity.WPF.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему" 
        Width="380" Height="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FFFFFF">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Вход в систему" 
                   FontFamily="Calibri" FontSize="22" FontWeight="Bold" 
                   Foreground="#B8860B" Margin="0,0,0,20"/>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Логин:" FontFamily="Calibri" FontSize="14" 
                       VerticalAlignment="Center"/>
            <TextBox x:Name="LoginTextBox" Grid.Column="1" 
                     FontFamily="Calibri" FontSize="14" Padding="5"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Пароль:" FontFamily="Calibri" FontSize="14" 
                       VerticalAlignment="Center"/>
            <PasswordBox x:Name="PasswordBox" Grid.Column="1" 
                         FontFamily="Calibri" FontSize="14" Padding="5"/>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,0,0,10">
            <Button Content="Отмена" 
                    Background="Gray" Foreground="White"
                    FontFamily="Calibri" FontSize="14"
                    Padding="15,6" Margin="0,0,10,0"
                    BorderThickness="0" Cursor="Hand"
                    Click="CancelButton_Click"/>
            <Button Content="Войти" 
                    Background="#B8860B" Foreground="White"
                    FontFamily="Calibri" FontSize="14"
                    Padding="15,6" BorderThickness="0" Cursor="Hand"
                    Click="LoginButton_Click"/>
        </StackPanel>

        <TextBlock x:Name="ErrorTextBlock" Grid.Row="4" 
                   FontFamily="Calibri" FontSize="24" 
                   Foreground="Red" Visibility="Collapsed"/>
    </Grid>
</Window>