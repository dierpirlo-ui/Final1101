<Window x:Class="ReadCity.WPF.Views.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ваш заказ"
        Width="700" Height="500"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="#FFFFFF">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#DAA520" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Ваш заказ"
                           FontFamily="Calibri" FontSize="20" FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock x:Name="ClientNameTextBlock" Grid.Column="1"
                           FontFamily="Calibri" FontSize="14"
                           Foreground="White" Visibility="Collapsed"/>
            </Grid>
        </Border>

        <DataGrid x:Name="OrderDataGrid" Grid.Row="1"
                  AutoGenerateColumns="False" CanUserAddRows="False"
                  FontFamily="Calibri" FontSize="13"
                  Margin="10" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  RowHeight="35">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название"
                                    Binding="{Binding Product.Name}"
                                    Width="*"/>
                <DataGridTextColumn Header="Цена"
                                    Binding="{Binding Product.DiscountedPrice, StringFormat={}{0:N2} руб.}"
                                    Width="100"/>
                <DataGridTemplateColumn Header="Кол-во" Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                     Width="50"
                                     HorizontalAlignment="Center"
                                     FontFamily="Calibri"
                                     FontSize="13"
                                     LostFocus="QuantityTextBox_LostFocus"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Сумма"
                                    Binding="{Binding TotalPrice, StringFormat={}{0:N2} руб.}"
                                    Width="100"/>
                <DataGridTemplateColumn Header="Удалить" Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="✕"
                                    Foreground="Red"
                                    FontSize="16" FontWeight="Bold"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand"
                                    Tag="{Binding}"
                                    Click="RemoveItemButton_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock x:Name="TotalTextBlock" Grid.Row="2"
                   FontFamily="Calibri" FontSize="16" FontWeight="Bold"
                   HorizontalAlignment="Right" Margin="15,5"
                   Foreground="#B8860B"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="15">
            <Button Content="Назад"
                    Background="Gray" Foreground="White"
                    FontFamily="Calibri" FontSize="14"
                    Padding="15,8" Margin="0,0,10,0"
                    BorderThickness="0" Cursor="Hand"
                    Click="BackButton_Click"/>
            <Button Content="Оформить заказ"
                    Background="#B8860B" Foreground="White"
                    FontFamily="Calibri" FontSize="14"
                    Padding="15,8" BorderThickness="0" Cursor="Hand"
                    Click="ConfirmOrderButton_Click"/>
        </StackPanel>
    </Grid>
</Window>