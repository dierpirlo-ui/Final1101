@page
@model ReadCity.Web.Pages.AddToOrderModel

@{
    ViewData["Title"] = "Подтверждение заказа";
}

<div style="text-align:center; padding:40px 20px;">
    <div style="max-width:500px; margin:0 auto; border:1px solid #ddd; border-radius:8px; padding:30px; background:white;">

        @if (Model.IsSuccess)
        {
            <h2 style="color:#B8860B;">Товар добавлен</h2>
            <p style="font-size:18px; margin:15px 0;">@Model.ProductName</p>
            <p>Цена: <strong style="color:#B8860B;">@Model.ProductPrice.ToString("N2") руб.</strong></p>
            <div style="margin-top:15px; padding:15px; background-color:#d4edda; border:1px solid #c3e6cb; border-radius:4px; color:#155724;">
                @Model.Message
            </div>
        }
        else
        {
            <h2 style="color:#dc3545;">@Model.ErrorTitle</h2>
            <div style="margin-top:15px; padding:15px; background-color:#f8d7da; border:1px solid #f5c6cb; border-radius:4px; color:#721c24;">
                @Model.Message
            </div>
        }

        <a href="/" style="display:inline-block; margin-top:20px; padding:10px 20px; background-color:#6c757d; color:white; text-decoration:none; border-radius:4px;">
            Вернуться
        </a>
    </div>
</div>